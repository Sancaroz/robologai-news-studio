generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BriefStatus {
  DRAFT
  READY
  APPROVED
}

model Brief {
  id               String      @id @default(cuid())
  sourceUrl        String
  sourceVideoId    String?
  sourceTitle      String
  sourceCompany    String
  thumbnailUrl     String?
  transcript       String      @db.Text
  newsScript       String      @db.Text
  youtubeTitle     String
  youtubeDescription String    @db.Text
  hashtags         String[]
  sourceCredit     String
  voiceoverScript  String      @db.Text
  status           BriefStatus @default(DRAFT)
  generatedWithAi  Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([createdAt])
  @@index([status])
}
